# Database Configuration
# Use a real PostgreSQL URL for production (e.g., from Google Cloud SQL)
DATABASE_URL=postgresql://user:password@localhost/votesmart

# Google AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Security
# Set this to your Firebase Hosting URL in production
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-project.web.app

# Environment
ENV=production
